# AI Agent Governance Simulator — environment configuration
# Copy this file to .env and adjust values as needed.

# SQLite database path for audit logs
AUDIT_DB_PATH=outputs/audit.db

# Minimum confidence threshold for auto-approval (0.0–1.0)
MIN_CONFIDENCE_THRESHOLD=0.70

# Refund approval thresholds (USD)
REFUND_MANAGER_THRESHOLD=500
REFUND_COMPLIANCE_THRESHOLD=2000

# Retention offer manager approval threshold (USD)
RETENTION_MANAGER_THRESHOLD=300

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
